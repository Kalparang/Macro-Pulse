# Copy to .env and run with:
# uv run python src/main.py --dry-run

# Telegram Config
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Discord Config
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# Optional web report URL
PAGES_REPORT_URL=https://your-github-username.github.io/your-repository/

# Optional data provider config
FRED_API_KEY=your_fred_api_key_here
BLS_API_KEY=your_optional_bls_api_key_here
SEC_USER_AGENT=Macro-Pulse Bot your-email@example.com
KRX_API_KEY=your_krx_api_key_here
KRX_KOSPI_STOCK_DAILY_URL=https://openapi.krx.co.kr/your-kospi-stock-daily-endpoint
KRX_KOSDAQ_STOCK_DAILY_URL=https://openapi.krx.co.kr/your-kosdaq-stock-daily-endpoint
KRX_INDEX_KOSPI_URL=https://openapi.krx.co.kr/your-kospi-index-daily-endpoint
KRX_INDEX_KOSDAQ_URL=https://openapi.krx.co.kr/your-kosdaq-index-daily-endpoint
KRX_INDEX_KRX_URL=https://openapi.krx.co.kr/your-krx-index-daily-endpoint
KRX_FUTURES_DAILY_URL=https://openapi.krx.co.kr/your-futures-daily-endpoint
KRX_ETF_DAILY_URL=https://openapi.krx.co.kr/your-etf-daily-endpoint
KRX_INVESTOR_FLOW_URL=https://openapi.krx.co.kr/your-investor-flow-endpoint
OPENDART_API_KEY=your_opendart_api_key_here
